# GitHub fine-grained token with Gists read/write permission.
TCPMS_GITHUB_TOKEN=github_pat_replace_me
TCPMS_DROPS_GIST_ID=replace_with_drops_gist_id
TCPMS_BADGES_GIST_ID=replace_with_badges_gist_id

# Twitch application credentials. The scraper obtains and renews an app token.
TCPMS_TWITCH_CLIENT_ID=replace_with_client_id
TCPMS_TWITCH_CLIENT_SECRET=replace_with_client_secret

# Optional: use a manually managed app/user token instead of the client secret.
TCPMS_TWITCH_OAUTH_TOKEN=

# Optional overrides.
TCPMS_DROPS_GIST_FILENAME=twitch-drops.json
TCPMS_BADGES_GIST_FILENAME=twitch-badges.json
TCPMS_DROPS_INTERVAL_SECONDS=900
TCPMS_BADGES_INTERVAL_SECONDS=1200
TCPMS_REQUEST_TIMEOUT_SECONDS=30
TCPMS_REQUEST_DELAY_SECONDS=0.25
TCPMS_OUTPUT_DIR=/data
