# GitHub fine-grained token with Gists read/write permission.
GITHUB_TOKEN=github_pat_replace_me
DROPS_GIST_ID=replace_with_drops_gist_id
BADGES_GIST_ID=replace_with_badges_gist_id

# Twitch application client ID and a matching user/app OAuth token.
TWITCH_CLIENT_ID=replace_with_client_id
TWITCH_OAUTH_TOKEN=replace_with_oauth_token

# Optional overrides.
DROPS_GIST_FILENAME=twitch-drops.json
BADGES_GIST_FILENAME=twitch-badges.json
DROPS_INTERVAL_SECONDS=900
BADGES_INTERVAL_SECONDS=1200
REQUEST_TIMEOUT_SECONDS=30
REQUEST_DELAY_SECONDS=0.25
OUTPUT_DIR=/data
